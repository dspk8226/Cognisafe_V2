<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/keyboard_ripple">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/keyboard_key_bg" />
            <stroke
                android:width="@dimen/keyboard_key_stroke_width"
                android:color="@color/keyboard_key_stroke" />
            <corners android:radius="@dimen/keyboard_key_radius" />
        </shape>
    </item>
</ripple>
